# Add these to ~/.hermes/.env

# App backend URLs
EXODUS_API_URL=http://localhost:3001/api
MUSE_API_URL=http://localhost:3002/api
SISYPHUS_API_URL=http://localhost:3003/api
PROGRESSION_API_URL=http://localhost:8000/api/v1

# Firebase auth (for Sisyphus & Progression)
# Run `python oracle/auth_setup.py` to get GOOGLE_REFRESH_TOKEN automatically
FIREBASE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Todoist REST API
TODOIST_API_TOKEN=
